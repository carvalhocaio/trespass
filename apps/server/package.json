{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@trespass/auth": "workspace:*",
    "@trespass/crypto": "workspace:*",
    "@trespass/db": "workspace:*",
    "@trespass/env": "workspace:*",
    "@trespass/github": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.8.2",
    "nanoid": "^5.1.11",
    "pino": "^9.14.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@trespass/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
